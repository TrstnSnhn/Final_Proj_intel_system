# Normalize source and documentation files so shell scripts and Python files
# keep predictable line endings across Windows/macOS/Linux.
* text=auto

*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.json text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.pt binary
*.pth binary
*.ckpt binary
*.onnx binary
